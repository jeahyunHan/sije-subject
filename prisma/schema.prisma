generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum OrderStatus {
  DRAFT
  PENDING
  CONFIRMED
  IN_PRODUCTION
  COMPLETED
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model Order {
  id            String      @id @default(uuid()) @db.Uuid
  orderNo       String      @unique @map("order_no")
  productName   String      @map("product_name")
  quantity      Int
  unitPrice     Decimal     @map("unit_price") @db.Decimal(12, 2)
  specification Json
  dueDate       DateTime    @map("due_date")
  status        OrderStatus @default(DRAFT)
  version       Int         @default(0)
  createdBy     String      @map("created_by")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  requests      Request[]
  histories     History[]

  @@index([status])
  @@map("orders")
}

model Request {
  id                String        @id @default(uuid()) @db.Uuid
  orderNo           String        @map("order_no")
  reason            String
  requestedQuantity Int?          @map("requested_quantity")
  requestedDueDate  DateTime?     @map("requested_due_date")
  requestedBy       String        @map("requested_by")
  reviewedBy        String?       @map("reviewed_by")
  reviewComment     String?       @map("review_comment")
  reviewedAt        DateTime?     @map("reviewed_at")
  status            RequestStatus @default(PENDING)
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")
  order             Order         @relation(fields: [orderNo], references: [orderNo], onDelete: Cascade)
  history           History?

  @@index([orderNo, status])
  @@index([status])
  @@map("requests")
}

model History {
  id            String      @id @default(uuid()) @db.Uuid
  orderNo       String      @map("order_no")
  requestId     String?     @unique @map("request_id") @db.Uuid
  version       Int
  productName   String      @map("product_name")
  quantity      Int
  unitPrice     Decimal     @map("unit_price") @db.Decimal(12, 2)
  specification Json
  dueDate       DateTime    @map("due_date")
  status        OrderStatus
  createdBy     String      @map("created_by")
  changedFields Json?       @map("changed_fields")
  approvedBy    String?     @map("approved_by")
  effectiveAt   DateTime    @default(now()) @map("effective_at")
  createdAt     DateTime    @default(now()) @map("created_at")
  order         Order       @relation(fields: [orderNo], references: [orderNo], onDelete: Cascade)
  request       Request?    @relation(fields: [requestId], references: [id], onDelete: SetNull)

  @@unique([orderNo, version])
  @@index([orderNo, effectiveAt])
  @@map("histories")
}
